# =============================================================================
# Environment Variables — Copy this file to .env and fill in your keys
# =============================================================================
#   cp .env.example .env
# =============================================================================

# Google Gemini API Key (for AI-assisted emotion annotation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) HuggingFace token for uploading the final dataset
HF_TOKEN=your_huggingface_token_here
